---
date: "{{ decision.decision_date }}"
type: decision
kind: decision
summary: "{{ summary }}"
status: active
confidence: medium
tags: [decision, researchos]
project: {{ decision.project_slug or "null" }}
cssclasses: [decision-page]
researchos:
  session_id: "{{ session.id }}"
  needs_addressed: {{ needs_addressed_yaml }}
  selected_products:
{%- for p in decision.selected_products %}
    - name: "{{ p.name }}"
      price: {{ p.price or 0 }}
      source_url: "{{ p.source_url }}"
{%- endfor %}
  total_cost: {{ decision.total_cost }}
  budget_category: {{ decision.budget_category or "null" }}
  alternatives_considered: {{ decision.alternatives_considered }}
  search_mode: "quality"
---

