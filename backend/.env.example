# ResearchOS Backend Configuration
# Copy to .env and fill in your values

# Service URLs (adjust to your infrastructure)
RESEARCHOS_VANE_URL=http://localhost:3001
RESEARCHOS_QWEN_URL=http://localhost:8080
RESEARCHOS_FIRECRAWL_URL=http://localhost:3002

# Wiki path (absolute path to your Obsidian vault wiki directory)
RESEARCHOS_WIKI_PATH=./wiki

# SQLite database path
RESEARCHOS_DB_PATH=researchos.db

# Vane model configuration (from your Vane settings page)
RESEARCHOS_VANE_CHAT_PROVIDER_ID=
RESEARCHOS_VANE_CHAT_MODEL_KEY=
RESEARCHOS_VANE_EMBED_PROVIDER_ID=
RESEARCHOS_VANE_EMBED_MODEL_KEY=
